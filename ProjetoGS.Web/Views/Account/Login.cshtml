@model ProjetoGS.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="row justify-content-center align-items-center page-fade-in" style="min-height: 70vh;">
    <div class="col-md-5">
        <div class="glass-card p-5">
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock-fill glowing-text-purple" style="font-size: 3rem;"></i>
                <h2 class="h4 mt-2">Acesso ao Sistema</h2>
                <p class="text-muted text-sm">Entre com suas credenciais para gerenciar spinoffs espaciais.</p>
            </div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-danger bg-dark text-danger text-sm py-2 px-3 rounded-3 mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-muted"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-envelope-fill"></i></span>
                        <input asp-for="Email" class="form-control form-control-cyber" placeholder="exemplo@espacial.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger text-sm mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Senha" class="form-label text-muted"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-key-fill"></i></span>
                        <input asp-for="Senha" class="form-control form-control-cyber" placeholder="Sua senha secreta" />
                    </div>
                    <span asp-validation-for="Senha" class="text-danger text-sm mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-cyber w-100 mb-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
                </button>
            </form>

            <div class="text-center">
                <p class="text-muted mb-0 text-sm">Não possui uma conta? <a asp-action="Register" class="text-glowing glowing-text-cyan text-decoration-none fw-medium">Cadastre-se aqui</a></p>
            </div>
        </div>
        
        <div class="mt-4 glass-card p-3 text-center">
            <h5 class="h6 mb-2">Credenciais de Demonstração:</h5>
            <div class="d-flex justify-content-around text-start text-sm text-muted">
                <div>
                    <strong class="text-light">Administrador:</strong><br />
                    E-mail: <code>admin@espacial.com</code><br />
                    Senha: <code>Admin123!</code>
                </div>
                <div>
                    <strong class="text-light">Pesquisador:</strong><br />
                    E-mail: <code>pesquisador@espacial.com</code><br />
                    Senha: <code>Pesq123!</code>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
