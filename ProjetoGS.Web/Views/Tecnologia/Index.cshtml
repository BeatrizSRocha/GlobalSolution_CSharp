@model IEnumerable<ProjetoGS.Web.Models.TecnologiaViewModel>
@{
    ViewData["Title"] = "Catálogo de Spinoffs";
}

<div class="page-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="glowing-text-cyan mb-1">Catálogo de Tecnologias</h1>
            <p class="text-muted">Explore inovações nascidas para missões espaciais que hoje facilitam a vida na Terra.</p>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-action="Create" class="btn btn-cyber">
                <i class="bi bi-plus-lg me-2"></i>Cadastrar Nova
            </a>
        }
    </div>

    <!-- Search & Filter Card -->
    <div class="glass-card p-4 mb-5">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label for="search" class="form-label text-muted text-sm">Pesquisar por Palavra-Chave</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" id="search" name="search" class="form-control form-control-cyber" 
                           placeholder="Ex: Espuma, Apollo, Câmeras..." value="@ViewBag.Search" />
                </div>
            </div>
            
            <div class="col-md-4">
                <label for="categoryId" class="form-label text-muted text-sm">Filtrar por Setor Terrestre</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-funnel-fill"></i></span>
                    <select id="categoryId" name="categoryId" class="form-select form-control-cyber form-select-cyber" asp-items="ViewBag.Categorias">
                        <option value="">-- Todos os Setores --</option>
                    </select>
                </div>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-cyber flex-grow-1">
                    <i class="bi bi-filter me-1"></i>Filtrar
                </button>
                <a asp-action="Index" class="btn btn-cyber-outline flex-grow-1 text-center">
                    Limpar
                </a>
            </div>
        </form>
    </div>

    <!-- Technologies Grid -->
    @if (!Model.Any())
    {
        <div class="glass-card p-5 text-center my-5">
            <i class="bi bi-database-exclamation text-muted" style="font-size: 3rem;"></i>
            <h3 class="h5 mt-3 text-light">Nenhuma tecnologia localizada</h3>
            <p class="text-muted">Experimente ajustar os filtros de busca ou verifique se o catálogo possui registros.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var badgeClass = "badge-default";
                if (item.CategoriaImpacto?.Nome == "Saúde") badgeClass = "badge-saude";
                else if (item.CategoriaImpacto?.Nome == "Agricultura") badgeClass = "badge-agricultura";
                else if (item.CategoriaImpacto?.Nome == "Consumo") badgeClass = "badge-consumo";
                else if (item.CategoriaImpacto?.Nome == "Energia") badgeClass = "badge-energia";
                else if (item.CategoriaImpacto?.Nome == "Transporte") badgeClass = "badge-transporte";

                <div class="col-md-6 col-lg-4">
                    <div class="glass-card h-100 d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge badge-cyber @badgeClass">
                                @(item.CategoriaImpacto?.Nome ?? "Outros")
                            </span>
                            <small class="text-muted"><i class="bi bi-calendar-event me-1"></i>@item.AnoInovacao</small>
                        </div>
                        
                        <h3 class="h5 text-white mb-2 glowing-text-purple">@item.Nome</h3>
                        
                        <p class="text-muted text-sm flex-grow-1 mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                            @item.Descricao
                        </p>

                        <div class="border-top border-secondary pt-3 mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-sm text-secondary">
                                    <i class="bi bi-rocket-takeoff-fill me-1"></i>Missão: <strong>@item.MissaoOrigem</strong>
                                </span>
                            </div>
                            
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-cyber-outline flex-grow-1">
                                    <i class="bi bi-eye"></i> Detalhes
                                </a>
                                
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-cyber py-1 px-3" title="Editar">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-cyber-danger py-1 px-3" title="Excluir">
                                            <i class="bi bi-trash3-fill"></i>
                                        </a>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
