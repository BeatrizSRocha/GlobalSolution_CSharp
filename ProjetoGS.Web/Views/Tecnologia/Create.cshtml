@model ProjetoGS.Web.Models.TecnologiaViewModel
@{
    ViewData["Title"] = "Cadastrar Tecnologia";
}

<div class="page-fade-in my-4">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-cyber-outline">
            <i class="bi bi-arrow-left me-1"></i>Voltar ao Catálogo
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-card p-5">
                <div class="text-center mb-5 border-bottom border-secondary pb-3">
                    <i class="bi bi-rocket-fill glowing-text-cyan" style="font-size: 2.5rem;"></i>
                    <h2 class="h3 text-white mt-2">Registrar Herança Espacial</h2>
                    <p class="text-muted">Adicione uma nova inovação oriunda de explorações e programas espaciais.</p>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-danger bg-dark text-danger text-sm py-2 px-3 rounded-3 mb-4" role="alert"></div>

                    <!-- Nome da Tecnologia -->
                    <div class="mb-3">
                        <label asp-for="Nome" class="form-label text-light fw-medium"></label>
                        <input asp-for="Nome" class="form-control form-control-cyber" placeholder="Ex: Espuma Viscoelástica, Filtro de Água de Íons..." />
                        <span asp-validation-for="Nome" class="text-danger text-sm mt-1 d-block"></span>
                    </div>

                    <div class="row mb-3">
                        <!-- Missão de Origem -->
                        <div class="col-md-6">
                            <label asp-for="MissaoOrigem" class="form-label text-light fw-medium"></label>
                            <input asp-for="MissaoOrigem" class="form-control form-control-cyber" placeholder="Ex: Programa Apollo, Skylab, JPL" />
                            <span asp-validation-for="MissaoOrigem" class="text-danger text-sm mt-1 d-block"></span>
                        </div>
                        
                        <!-- Ano Inovação -->
                        <div class="col-md-6">
                            <label asp-for="AnoInovacao" class="form-label text-light fw-medium"></label>
                            <input asp-for="AnoInovacao" class="form-control form-control-cyber" type="number" placeholder="Ex: 1969" />
                            <span asp-validation-for="AnoInovacao" class="text-danger text-sm mt-1 d-block"></span>
                        </div>
                    </div>

                    <!-- Categoria Impacto -->
                    <div class="mb-3">
                        <label asp-for="CategoriaImpactoId" class="form-label text-light fw-medium"></label>
                        <select asp-for="CategoriaImpactoId" class="form-select form-control-cyber form-select-cyber" asp-items="ViewBag.CategoriaImpactoId">
                            <option value="">-- Selecione o Setor Terrestre Beneficiado --</option>
                        </select>
                        <span asp-validation-for="CategoriaImpactoId" class="text-danger text-sm mt-1 d-block"></span>
                    </div>

                    <!-- Descrição -->
                    <div class="mb-3">
                        <label asp-for="Descricao" class="form-label text-light fw-medium"></label>
                        <textarea asp-for="Descricao" class="form-control form-control-cyber" rows="4" placeholder="Explique como a tecnologia foi desenvolvida no contexto espacial..."></textarea>
                        <span asp-validation-for="Descricao" class="text-danger text-sm mt-1 d-block"></span>
                    </div>

                    <!-- Benefício na Terra -->
                    <div class="mb-4">
                        <label asp-for="BeneficioTerra" class="form-label text-light fw-medium"></label>
                        <textarea asp-for="BeneficioTerra" class="form-control form-control-cyber" rows="4" placeholder="Descreva os benefícios e utilidades comerciais que a inovação trouxe para a Terra..."></textarea>
                        <span asp-validation-for="BeneficioTerra" class="text-danger text-sm mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4 border-top border-secondary pt-4">
                        <a asp-action="Index" class="btn btn-cyber-outline">Cancelar</a>
                        <button type="submit" class="btn btn-cyber">
                            <i class="bi bi-save2 me-2"></i>Registrar Tecnologia
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
