@model ProjetoGS.Web.Models.TecnologiaViewModel
@{
    ViewData["Title"] = "Excluir Tecnologia";
}

<div class="page-fade-in my-4">
    <div class="row justify-content-center">
        <div class="col-md-7 text-center">
            <div class="glass-card p-5 border border-danger">
                <i class="bi bi-trash3-fill text-danger mb-4" style="font-size: 4rem; filter: drop-shadow(0 0 10px rgba(238, 82, 83, 0.4));"></i>
                
                <h2 class="h3 text-danger mb-4">Confirmar Exclusão</h2>
                
                <p class="text-light lead mb-4">
                    Você tem certeza que deseja remover permanentemente o registro da tecnologia:
                    <br />
                    <strong class="text-white glowing-text-purple d-block fs-3 mt-2">@Model.Nome</strong>
                </p>

                <div class="alert alert-warning border-warning bg-dark text-warning text-start text-sm mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Aviso:</strong> Esta ação é irreversível. O registro será excluído permanentemente do banco de dados e as estatísticas do painel serão recalculadas.
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn btn-cyber-outline">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-cyber-danger">
                            <i class="bi bi-trash-fill me-2"></i>Excluir Registro
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
