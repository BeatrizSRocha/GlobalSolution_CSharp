@model ProjetoGS.Web.Models.TecnologiaViewModel
@{
    ViewData["Title"] = Model.Nome;
    
    var badgeClass = "badge-default";
    if (Model.CategoriaImpacto?.Nome == "Saúde") badgeClass = "badge-saude";
    else if (Model.CategoriaImpacto?.Nome == "Agricultura") badgeClass = "badge-agricultura";
    else if (Model.CategoriaImpacto?.Nome == "Consumo") badgeClass = "badge-consumo";
    else if (Model.CategoriaImpacto?.Nome == "Energia") badgeClass = "badge-energia";
    else if (Model.CategoriaImpacto?.Nome == "Transporte") badgeClass = "badge-transporte";
}

<div class="page-fade-in my-4">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-cyber-outline">
            <i class="bi bi-arrow-left me-1"></i>Voltar ao Catálogo
        </a>
    </div>

    <div class="glass-card p-5">
        <div class="d-flex justify-content-between align-items-start border-bottom border-secondary pb-4 mb-4">
            <div>
                <span class="badge badge-cyber @badgeClass mb-2">
                    @(Model.CategoriaImpacto?.Nome ?? "Outros")
                </span>
                <h1 class="display-5 text-white glowing-text-purple mb-2">@Model.Nome</h1>
                <p class="text-secondary mb-0">
                    <i class="bi bi-clock me-1"></i>Cadastrado em @Model.DataCadastro.ToLocalTime().ToString("dd/MM/yyyy 'às' HH:mm")
                </p>
            </div>
            <div class="text-end bg-dark border border-secondary p-3 rounded-3">
                <span class="text-muted d-block text-sm">Ano de Inovação</span>
                <span class="h2 text-info fw-bold mb-0">@Model.AnoInovacao</span>
            </div>
        </div>

        <div class="row g-5">
            <!-- Left Info Block -->
            <div class="col-lg-7">
                <h3 class="h5 text-glowing glowing-text-cyan mb-3">
                    <i class="bi bi-info-circle-fill me-2"></i>Descrição e Contexto Histórico
                </h3>
                <p class="lead text-light mb-4" style="line-height: 1.8;">
                    @Model.Descricao
                </p>

                <h3 class="h5 text-success mb-3">
                    <i class="bi bi-house-heart-fill me-2"></i>Impacto e Benefícios na Terra
                </h3>
                <div class="p-4 rounded-3 border border-success" style="background-color: rgba(16, 172, 132, 0.05);">
                    <p class="text-light mb-0" style="line-height: 1.7;">
                        @Model.BeneficioTerra
                    </p>
                </div>
            </div>

            <!-- Right Technical Details Sidebar -->
            <div class="col-lg-5">
                <div class="p-4 rounded-4 border border-secondary" style="background-color: rgba(15, 17, 26, 0.4);">
                    <h4 class="h6 text-muted uppercase mb-4 tracking-wider">Metadados de Origem</h4>
                    
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="metric-icon icon-purple flex-shrink-0" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                <i class="bi bi-rocket-takeoff-fill"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Missão Original</small>
                                <span class="text-white fw-bold">@Model.MissaoOrigem</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3">
                            <div class="metric-icon icon-cyan flex-shrink-0" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                <i class="bi bi-tag-fill"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Setor Beneficiado</small>
                                <span class="text-white fw-bold">@(Model.CategoriaImpacto?.Nome ?? "Indefinido")</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3">
                            <div class="metric-icon icon-green flex-shrink-0" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                <i class="bi bi-calendar-check-fill"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Ano da Transferência</small>
                                <span class="text-white fw-bold">@Model.AnoInovacao</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="mt-4 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-cyber flex-grow-1">
                            <i class="bi bi-pencil-square me-2"></i>Editar Registro
                        </a>
                        
                        @if (User.IsInRole("Administrador"))
                        {
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-cyber-danger flex-grow-1 text-center">
                                <i class="bi bi-trash-fill me-2"></i>Excluir
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
